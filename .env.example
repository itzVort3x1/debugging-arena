# ---- Database (Supabase Postgres) ----
# Both strings come from Supabase -> Project Settings -> Database -> Connection string.
#
# DATABASE_URL: the POOLED connection (Transaction mode, port 6543). Used by the
# app at runtime. Keep the ?pgbouncer=true flag.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL: the DIRECT connection (Session mode, port 5432). Used only for
# `prisma migrate` / `prisma db push`, which can't run through the pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- NextAuth ----
# Dev URL. In production set this to your public origin, e.g.
#   NEXTAUTH_URL="https://arena.example.com"
NEXTAUTH_URL="http://localhost:3000"
# Required in every environment. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ---- Anthropic ----
# Phase 7 (AI postmortem). Not required to run the app today; leave blank for now.
ANTHROPIC_API_KEY=""

# ---- Challenge runner ----
# How challenge test suites execute:
#   docker (default) — run each suite in an isolated arena-node container
#                      (no network, dropped caps, resource caps, host env NOT
#                      inherited). Requires the Docker engine running and the
#                      image built once: `npm run docker:build:node`.
#   host             — run in-process on the host. NO isolation; inherits this
#                      machine's environment. Dev/CI escape hatch only — never
#                      use in a deployed environment.
# Leave unset to default to docker.
ARENA_RUNNER="docker"
