# ---- Database ----
# Dev: SQLite file, path is relative to prisma/schema.prisma
DATABASE_URL="file:./dev.db"
# Production (long-running Node host): point at a file on a PERSISTENT disk, e.g.
#   DATABASE_URL="file:/data/prod.db"

# ---- NextAuth ----
# Dev URL. In production set this to your public origin, e.g.
#   NEXTAUTH_URL="https://arena.example.com"
NEXTAUTH_URL="http://localhost:3000"
# Required in every environment. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# ---- Anthropic ----
# Phase 7 (AI postmortem). Not required to run the app today; leave blank for now.
ANTHROPIC_API_KEY=""
